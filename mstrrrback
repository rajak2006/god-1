# ⚙️ 5. Role Task (`roles/mstr_backup/tasks/main.yml`)

```yaml
- name: Ensure backup directory exists
  file:
    path: "{{ backup_path }}"
    state: directory
    mode: '0770'

- name: Deploy response.json
  template:
    src: response.json.j2
    dest: "{{ response_file }}"
    mode: '0600'

- name: Run MSTR backup
  shell: ./mstrbak --responseFile {{ response_file }}
  args:
    chdir: /opt/mstrbkc/Mstrbak-client
  register: backup_result
  failed_when: "'ERROR' in backup_result.stdout"

- name: Save backup log
  copy:
    content: "{{ backup_result.stdout }}"
    dest: "{{ backup_path }}/backup_{{ ansible_date_time.iso8601 }}.log"

- name: Show output
  debug:
    var: backup_result.stdout
```

