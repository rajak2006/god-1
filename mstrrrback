# ===== USER INPUT =====
read -p "Enter Project Name: " PROJECT_NAME
read -p "Enter project_source_name: " PROJECT_SOURCE
read -p "Enter mstr_version: " MSTR_VERSION
read -p "Enter DB Type (Oracle/MySQL/PostgreSQL): " DB_TYPE
read -p "Enter DSN Name: " DSN_NAME
read -p "Enter DB Username: " DB_USER
read -s -p "Enter DB Password: " DB_PASS
echo ""

read -p "Enter MSTR Username: " MSTR_USER
read -s -p "Enter MSTR Password: " MSTR_PASS
echo ""

# ===== COS INPUT =====
read -p "Enter COS Bucket Name: " BUCKET
read -p "Enter COS Endpoint: " ENDPOINT

# ===== VALIDATIONS =====
if [ ! -f "$BACKUP_CMD" ]; then
    echo "❌ mstrbak not found at $BACKUP_CMD"
    exit 1
fi

if [ ! -x "$UPLOAD_SCRIPT" ]; then
    echo "❌ Upload script not found or not executable: $UPLOAD_SCRIPT"
    exit 1
fi

# ===== CREATE RESPONSE.JSON =====
cat > "$RESPONSE_FILE" <<EOF
{
  "metadata": {
    "db type": "$DB_TYPE",
    "dsn_name": "$DSN_NAME",
    "username": "$DB_USER",
    "password": "$DB_PASS",
    "prefix": ""
  },
  "mstr": {
    "install_path": "/opt/",
    "server_definition": "vmserver.example.com",
    "project_source_name": "$PROJECT_SOURCE",
    "username": "$MSTR_USER",
    "password": "$MSTR_PASS",
    "mstr_version": "$MSTR_VERSION"
  },
  "backup_options": {
    "metadata": true,
    "keep_same_projects_loaded": true
  },
  "mstrbak": {
    "backup_path": "$BACKUP_DIR",
    "response_file_path": "$RESPONSE_FILE"
  }
}
EOF

echo "✅ response.json created"

# ===== RUN BACKUP =====
echo "🚀 Running MSTR backup..."

if ! "$BACKUP_CMD" -r "$RESPONSE_FILE" > "$LOG_FILE" 2>&1; then
    echo "❌ Backup execution failed"
    echo "📄 Log: $LOG_FILE"
    exit 1
fi

# ===== VERIFY SUCCESS =====
if grep -q "finished successfully" "$LOG_FILE"; then
    echo "✅ Backup completed successfully"
else
    echo "❌ Backup failed"
    echo "📄 Log File: $LOG_FILE"
    tail -20 "$LOG_FILE"
    exit 1
fi

# ===== EXTRACT BACKUP FILE =====
BACKUP_PATH=$(grep -i "archive created locally at" "$LOG_FILE" | awk -F'at: ' '{print $2}')

if [ -z "$BACKUP_PATH" ]; then
    echo "❌ Backup file path not found in logs"
    exit 1
fi

# ===== RENAME BACKUP FILE =====
DIR_NAME=$(dirname "$BACKUP_PATH")
FILE_NAME=$(basename "$BACKUP_PATH")

NEW_NAME="${PROJECT_NAME}-backup-${FILE_NAME}"
NEW_PATH="$DIR_NAME/$NEW_NAME"

mv "$BACKUP_PATH" "$NEW_PATH"

echo "📦 Renamed Backup: $NEW_PATH"

# ===== CALL EXISTING UPLOAD SCRIPT =====
echo "☁️ Uploading via external script..."

if "$UPLOAD_SCRIPT" "$NEW_PATH" "$BUCKET" "$ENDPOINT"; then
    echo "✅ Upload successful"
else
    echo "❌ Upload failed"
    exit 1
fi

# ===== CLEANUP OLD BACKUPS (7 days) =====
find "$BACKUP_DIR" -name "*.tar.gz" -mtime +7 -delete

# ===== FINAL OUTPUT =====
echo "======================================"
echo "✅ Backup + Upload Completed"
echo "📦 Backup File: $NEW_PATH"
echo "☁️ Bucket: s3://$BUCKET/$(basename "$NEW_PATH")"
echo "📄 Log File: $LOG_FILE"
echo "======================================"
