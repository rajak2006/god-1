# Construct namespace dynamically
namespace_name: "{{ (appid ~ '-' ~ env ~ '-' ~ application) | lower | regex_replace('[^a-z0-9-]', '-') }}"
####namespace_name: "{{ (appid ~ '_' ~ env ~ '_' ~ application) | lower | regex_replace('[^a-z0-9_]', '-') }}"

namespace_display_name: "{{ application }} ({{ env }})"
namespace_description: "Namespace for {{ application }} in {{ env }}"
-------------------------
. Role Tasks (Core Logic)
roles/ocp_namespace/tasks/main.yml
- name: Validate required variables
  fail:
    msg: "appid, env, and application must be provided"
  when: appid == "" or env == "" or application == ""

- name: Show computed namespace
  debug:
    msg: "Namespace will be: {{ namespace_name }}"

# Check if namespace exists
- name: Check if namespace exists
  shell: oc get project {{ namespace_name }} --no-headers
  register: ns_check
  ignore_errors: true
  changed_when: false

# Create namespace if not exists
- name: Create namespace
  shell: oc new-project {{ namespace_name }}
  when: ns_check.rc != 0

# Add annotations
- name: Set display name
  shell: >
    oc annotate namespace {{ namespace_name }}
    openshift.io/display-name="{{ namespace_display_name }}" --overwrite

- name: Set description
  shell: >
    oc annotate namespace {{ namespace_name }}
    openshift.io/description="{{ namespace_description }}" --overwrite

# Optional: Add labels (best practice)
- name: Add labels
  shell: >
    oc label namespace {{ namespace_name }}
    appid={{ appid }}
    env={{ env }}
    application={{ application }} --overwrite


