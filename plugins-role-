# 📌 tasks/validate.yml

```yaml
- name: Wait for pods running
  shell: >
    oc get pods -n {{ namespace }} -l {{ plugin_target_labels[0] }} -o jsonpath='{.items[*].status.phase}'
  register: pod_status
  until: "'Running' in pod_status.stdout"
  retries: 20
  delay: 15

- name: Validate plugin files
  shell: >
    oc exec -n {{ namespace }} {{ item }} -- ls {{ plugin_path }}
  register: plugin_check
  loop: "{{ final_pods }}"
  ignore_errors: yes

- name: Validate UI health
  shell: >
    curl -k https://{{ dns_entry }}/MicroStrategyLibrary/api/health
  register: ui_health
  ignore_errors: yes
```

