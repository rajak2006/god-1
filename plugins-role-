# 📌 tasks/precheck.yml

```yaml
- name: Get pods for each label
  shell: >
    oc get pods -n {{ namespace }} -l {{ item }} -o jsonpath='{.items[*].metadata.name}'
  loop: "{{ plugin_target_labels }}"
  register: pods_by_label

- name: Merge pod lists
  set_fact:
    final_pods: >-
      {{
        pods_by_label.results
        | map(attribute='stdout')
        | map('split')
        | list
        | flatten
        | unique
      }}

- name: Override with manual pod list
  set_fact:
    final_pods: "{{ plugin_target_pods }}"
  when: plugin_target_pods | length > 0

- name: Fail if no pods found
  fail:
    msg: "No target pods found"
  when: final_pods | length == 0

- name: Create local backup dir
  file:
    path: "{{ backup_local_dir }}"
    state: directory
```

---

# 📌 tasks/backup.yml

```yaml
- name: Generate timestamp
  set_fact:
    backup_timestamp: "{{ lookup('pipe', 'date +%Y%m%d%H%M%S') }}"

- name: Backup plugins from pods
  shell: >
    oc cp {{ namespace }}/{{ item }}:{{ plugin_path }}
    {{ backup_local_dir }}/{{ item }}-{{ backup_timestamp }}
  loop: "{{ final_pods }}"
  ignore_errors: yes
```

---

# 📌 tasks/deploy.yml

```yaml
- name: Create temp dir
  file:
    path: "{{ plugin_tmp_dir }}"
    state: directory

- name: Decide plugin list (deploy or rollback)
  set_fact:
    active_plugins: "{{ new_plugins if rollback_plugins | length == 0 else rollback_plugins }}"

- name: Copy plugins locally
  copy:
    src: "{{ plugin_source_dir }}/{{ item }}"
    dest: "{{ plugin_tmp_dir }}/"
  loop: "{{ active_plugins }}"

- name: Extract plugins
  unarchive:
    src: "{{ plugin_tmp_dir }}/{{ item }}"
    dest: "{{ plugin_tmp_dir }}/{{ item | replace('.zip','') }}"
    remote_src: yes
  loop: "{{ active_plugins }}"

- name: Deploy plugins to pods
  shell: >
    oc cp {{ plugin_tmp_dir }}/{{ item_plugin | replace('.zip','') }}/.
    {{ namespace }}/{{ item_pod }}:{{ plugin_path }}
  loop: "{{ active_plugins | product(final_pods) | list }}"
  loop_control:
    loop_var: combo
  vars:
    item_plugin: "{{ combo.0 }}"
    item_pod: "{{ combo.1 }}"

- name: Restart pods
  shell: >
    oc delete pod -n {{ namespace }} {{ item }}
  loop: "{{ final_pods }}"
```

