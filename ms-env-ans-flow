# 14️⃣ Audit Logging

`tasks/audit.yml`

```yaml
- name: Ensure audit directory exists
  file:
    path: "{{ audit_log_dir }}"
    state: directory

- name: Write audit log
  copy:
    dest: "{{ audit_log_dir }}/deploy_{{ ansible_date_time.iso8601 }}.log"
    content: |
      Deployment Timestamp: {{ ansible_date_time.iso8601 }}
      Namespace: {{ namespace }}
      User: {{ ocp_user }}
      SMCP Status: {{ smcp_status.stdout }}
      SMMR Members: {{ smmr_status.stdout }}

- name: Find audit logs
  find:
    paths: "{{ audit_log_dir }}"
    patterns: "*.log"
  register: logs

- name: Delete older logs (keep last 5)
  file:
    path: "{{ item.path }}"
    state: absent
  loop: "{{ logs.files | sort(attribute='mtime')[:-5] }}"
  when: logs.matched > 5
```

