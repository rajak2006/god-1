## `roles/audit_logging/tasks/main.yml`

```yaml id="auditfinal001"
# ===================================================
# Ensure log directory exists
# ===================================================
- name: Create audit log directory
  file:
    path: "{{ audit_log_dir }}"
    state: directory
    mode: "0755"

# ===================================================
# Generate current log filename
# ===================================================
- name: Generate audit log file name
  set_fact:
    audit_log_file: >
      {{ audit_log_dir }}/{{ audit_log_prefix }}_{{ lookup('pipe','date +%Y%m%d_%H%M%S') }}.log

# ===================================================
# Create log file
# ===================================================
- name: Create audit log file
  file:
    path: "{{ audit_log_file }}"
    state: touch
    mode: "0644"

# ===================================================
# Find all logs sorted by newest
# ===================================================
- name: Get existing logs (newest first)
  shell: |
    ls -1t {{ audit_log_dir }}/{{ audit_log_prefix }}_*.log 2>/dev/null || true
  register: existing_logs
  changed_when: false

# ===================================================
# Rotate logs (KEEP ONLY LAST N)
# ===================================================
- name: Delete old logs (keep last {{ audit_log_keep_last }})
  file:
    path: "{{ item }}"
    state: absent
  loop: "{{ existing_logs.stdout_lines[audit_log_keep_last:] }}"
  when: existing_logs.stdout_lines | length > audit_log_keep_last

# ===================================================
# Audit header
# ===================================================
- name: Write audit header
  lineinfile:
    path: "{{ audit_log_file }}"
    line: |
      ===== MSTR INSTALL START =====
      Cluster : {{ ocp_cluster }}
      User    : {{ ocp_user }}
      Time    : {{ lookup('pipe','date') }}
```

