# 🛠️ OpenShift (OCP) Namespace Audit Script

```bash id="ocp-ns-audit"
#!/bin/bash

NAMESPACE=$1

if [ -z "$NAMESPACE" ]; then
  echo "Usage: $0 <namespace>"
  exit 1
fi

echo "===== POD RESOURCE USAGE (Namespace: $NAMESPACE) ====="
oc get pods -n $NAMESPACE -o json | jq -r '
.items[] |
select(.status.phase=="Running") |
[
  .metadata.name,
  .spec.nodeName,
  (.spec.containers[]?.resources.requests.cpu // "0"),
  (.spec.containers[]?.resources.requests.memory // "0"),
  (.spec.containers[]?.resources.limits.cpu // "0"),
  (.spec.containers[]?.resources.limits.memory // "0")
] | @tsv' | column -t

echo ""
echo "===== DEPLOYMENTS ====="
oc get deploy -n $NAMESPACE -o json | jq -r '
.items[] |
[
  .metadata.name,
  .spec.replicas,
  (.spec.template.spec.containers[]?.resources.requests.cpu // "0"),
  (.spec.template.spec.containers[]?.resources.requests.memory // "0"),
  (.spec.template.spec.containers[]?.resources.limits.cpu // "0"),
  (.spec.template.spec.containers[]?.resources.limits.memory // "0")
] | @tsv' | column -t

echo ""
echo "===== STATEFULSETS ====="
oc get statefulset -n $NAMESPACE -o json | jq -r '
.items[] |
[
  .metadata.name,
  .spec.replicas,
  (.spec.template.spec.containers[]?.resources.requests.cpu // "0"),
  (.spec.template.spec.containers[]?.resources.requests.memory // "0"),
  (.spec.template.spec.containers[]?.resources.limits.cpu // "0"),
  (.spec.template.spec.containers[]?.resources.limits.memory // "0")
] | @tsv' | column -t

echo ""
echo "===== STORAGE (PVCs) ====="
oc get pvc -n $NAMESPACE -o json | jq -r '
.items[] |
[
  .metadata.name,
  .spec.resources.requests.storage,
  .spec.storageClassName,
  .spec.volumeName
] | @tsv' | column -t
```

