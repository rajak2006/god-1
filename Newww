---
# =========================================
# LOGIN
# =========================================
- name: Login to OpenShift
  command: >
    oc login {{ ocp_api }} -u {{ ocp_user }} -p {{ ocp_pass }} --insecure-skip-tls-verify
  failed_when: false

# =========================================
# INIT
# =========================================
- name: Initialize audit list
  set_fact:
    audit_results: []

# =========================================
# PROCESS COMPONENTS
# =========================================
- name: Process components
  block:

    - name: Show component
      debug:
        msg: "Processing {{ item.name }}"

    # -------------------------------
    # RESTART
    # -------------------------------
    - name: Restart resource
      shell: |
        oc rollout restart deployment {{ item.selector }} -n {{ namespace }} 2>/dev/null || true
        oc rollout restart statefulset {{ item.selector }} -n {{ namespace }} 2>/dev/null || true
      failed_when: false

    # -------------------------------
    # GET POD
    # -------------------------------
    - name: Get pod name
      shell: |
        oc get pods -n {{ namespace }} --no-headers | grep {{ item.selector }} | grep -v Terminating | awk '{print $1}' | head -1
      register: pod_out
      until: pod_out.stdout != ""
      retries: 30
      delay: 10
      failed_when: false

    - name: Set pod_name
      set_fact:
        pod_name: "{{ pod_out.stdout | default('not-found') }}"

    # -------------------------------
    # WAIT RUNNING
    # -------------------------------
    - name: Wait for Running
      shell: oc get pod {{ pod_name }} -n {{ namespace }} -o jsonpath='{.status.phase}'
      register: pod_phase
      until: pod_phase.stdout == "Running"
      retries: 30
      delay: 10
      failed_when: false

    # -------------------------------
    # WAIT READY
    # -------------------------------
    - name: Wait for containers Ready
      shell: oc get pod {{ pod_name }} -n {{ namespace }} -o jsonpath='{.status.containerStatuses[*].ready}'
      register: pod_ready
      until: "'false' not in pod_ready.stdout"
      retries: 30
      delay: 10
      failed_when: false

    # -------------------------------
    # GET DETAILS
    # -------------------------------
    - name: Get pod details
      shell: oc get pod {{ pod_name }} -n {{ namespace }} -o json
      register: pod_json
      failed_when: false

    - name: Parse containers
      set_fact:
        container_statuses: "{{ (pod_json.stdout | default('{}') | from_json).status.containerStatuses | default([]) }}"

    - name: Find failed containers
      set_fact:
        failed_containers: "{{ container_statuses | selectattr('ready','equalto',false) | map(attribute='name') | list }}"

    # -------------------------------
    # FINAL STATUS
    # -------------------------------
    - name: Set status
      set_fact:
        pod_status: >-
          {% if pod_phase.stdout == "Running" and (failed_containers | length == 0) %}
          SUCCESS
          {% else %}
          FAILED
          {% endif %}

    - name: Warn if unhealthy
      debug:
        msg: "WARNING: {{ pod_name }} → {{ failed_containers }}"
      when: pod_status == "FAILED"

    # -------------------------------
    # SAVE AUDIT
    # -------------------------------
    - name: Save audit
      set_fact:
        audit_results: >-
          {{
            (audit_results | default([])) + [
              {
                'component': item.name,
                'pod': pod_name,
                'phase': pod_phase.stdout | default('unknown'),
                'status': pod_status,
                'failed_containers': failed_containers,
                'message': (
                  'All containers healthy'
                  if pod_status == 'SUCCESS'
                  else 'Failed containers: ' + (failed_containers | join(', '))
                )
              }
            ]
          }

  loop: "{{ restart_targets }}"

# =========================================
# COLLECT ALL PODS
# =========================================
- name: Get all pods
  shell: oc get pods -n {{ namespace }} -o json
  register: all_pods

- name: Set pod list
  set_fact:
    pods: "{{ (all_pods.stdout | from_json)['items'] }}"

# =========================================
# HTML REPORT
# =========================================
- name: Generate HTML report
  template:
    src: mstr_full_audit_report.html.j2
    dest: "{{ report_path }}"

- name: Show report path
  debug:
    msg: "Report: {{ report_path }}"


