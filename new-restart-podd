# 📄 vars/vars.yml

```yaml
---
components:
  - name: library
    selector: "app=library"

  - name: iserver
    selector: "app=iserver"

  - name: web
    selector: "app=web"

  - name: mobile
    selector: "app=mobile"
```

---

# 📄 tasks/main.yml (Orchestrator)

```yaml
---
- name: Initialize audit results
  set_fact:
    audit_results: []

- name: Restart all components
  include_tasks: restart.yml

- name: Collect full pod inventory
  include_tasks: collect-pods.yml

- name: Generate HTML report
  template:
    src: report.html.j2
    dest: "{{ report_path }}"

- name: Display report location
  debug:
    msg: "Report generated at {{ report_path }}"
```

---

# 📄 tasks/restart.yml

```yaml
---
- name: Process each component
  include_tasks: process_component.yml
  loop: "{{ components }}"
  loop_control:
    loop_var: component
```

---

# 📄 tasks/process_component.yml

```yaml
---
- name: Get workloads for component {{ component.name }}
  command: >
    oc get deployment,statefulset -n {{ namespace }}
    -l {{ component.selector }} -o json
  register: workload_json
  failed_when: false

- name: Parse workloads
  set_fact:
    workloads: "{{ workload_json.stdout | from_json }}"

- name: Restart workloads
  command: >
    oc rollout restart {{ item.kind | lower }}/{{ item.metadata.name }} -n {{ namespace }}
  loop: "{{ workloads.items }}"
  register: restart_result
  failed_when: false

- name: Wait for pods to stabilize
  command: >
    oc get pods -n {{ namespace }} -l {{ component.selector }} -o json
  register: pod_status
  retries: "{{ retry_count }}"
  delay: "{{ retry_delay }}"
  until: >
    (
      pod_status.stdout | from_json
    ).items | length > 0
  failed_when: false

- name: Evaluate pod health
  set_fact:
    pod_list: "{{ pod_status.stdout | from_json }}"

- name: Build component audit result
  set_fact:
    component_result:
      component: "{{ component.name }}"
      pods: >-
        {{
          pod_list.items | map(attribute='metadata.name') | list
        }}
      pod_details: >-
        {{
          pod_list.items | map('extract', {
            'name': 'metadata.name',
            'phase': 'status.phase',
            'ready': 'status.containerStatuses'
          }) | list
        }}

- name: Detect failures
  set_fact:
    component_result: "{{ component_result | combine({'status': comp_status}) }}"
  vars:
    comp_status: >-
      {{
        'FAILED' if (
          pod_list.items | selectattr('status.phase','ne','Running') | list | length > 0
          or
          pod_list.items | selectattr('status.containerStatuses','defined')
          | selectattr('status.containerStatuses','selectattr','ready','equalto',false)
          | list | length > 0
        ) else 'SUCCESS'
      }}

- name: Append to audit results
  set_fact:
    audit_results: "{{ audit_results + [component_result] }}"
```

---

# 📄 tasks/collect-pods.yml

```yaml
---
- name: Collect all pods in namespace
  command: >
    oc get pods -n {{ namespace }} -o json
  register: all_pods
  failed_when: false

- name: Parse all pods
  set_fact:
    all_pod_inventory: "{{ all_pods.stdout | from_json }}"

- name: Add inventory to audit
  set_fact:
    audit_results: "{{ audit_results + [{'full_inventory': all_pod_inventory.items}] }}"
```

