# 🎨 templates/report.html.j2

```html
<!DOCTYPE html>
<html>
<head>
    <title>MicroStrategy Restart Audit Report</title>
    <style>
        body { font-family: Arial; background: #f4f4f4; }
        h1 { color: #333; }
        .component {
            border: 1px solid #ccc;
            padding: 10px;
            margin: 10px;
            background: white;
        }
        .success { color: green; }
        .failed { color: red; }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th, td {
            border: 1px solid #ddd;
            padding: 8px;
        }
    </style>
</head>

<body>

<h1>MicroStrategy OCP Restart Audit Report</h1>

{% for comp in audit_results %}
  {% if comp.component is defined %}
  <div class="component">
    <h2>{{ comp.component }}</h2>

    <p>Status:
      <span class="{{ comp.status | lower }}">
        {{ comp.status }}
      </span>
    </p>

    <table>
      <tr>
        <th>Pod Name</th>
        <th>Phase</th>
        <th>Ready Containers</th>
      </tr>

      {% for pod in comp.pod_details %}
      <tr>
        <td>{{ pod.metadata.name }}</td>
        <td>{{ pod.status.phase }}</td>
        <td>
          {% for c in pod.status.containerStatuses %}
            {{ c.name }}: {{ c.ready }}<br>
          {% endfor %}
        </td>
      </tr>
      {% endfor %}
    </table>
  </div>
  {% endif %}
{% endfor %}

<h2>Full Pod Inventory</h2>
<ul>
{% for item in audit_results %}
  {% if item.full_inventory is defined %}
    {% for pod in item.full_inventory %}
      <li>{{ pod.metadata.name }} - {{ pod.status.phase }}</li>
    {% endfor %}
  {% endif %}
{% endfor %}
</ul>

</body>
</html>
```

