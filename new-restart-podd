```yaml
---
- name: Get workloads
  command: >
    oc get deployment,statefulset -n {{ namespace }}
    -l {{ component.selector }} -o json
  register: workload_json
  failed_when: false

- set_fact:
    workloads: "{{ workload_json.stdout | from_json }}"

- name: Restart workloads
  command: >
    oc rollout restart {{ item.kind | lower }}/{{ item.metadata.name }} -n {{ namespace }}
  loop: "{{ workloads.get('items', []) }}"
  when: workloads.get('items', []) | length > 0
  failed_when: false

# -------------------------
# WAIT PHASE 1: Pods Exist
# -------------------------
- name: Wait for pods to appear
  command: >
    oc get pods -n {{ namespace }} -l {{ component.selector }} -o json
  register: pod_status_exist
  retries: 10
  delay: 10
  until: >
    (pod_status_exist.stdout | from_json).get('items', []) | length > 0
  failed_when: false

# -------------------------
# WAIT PHASE 2: Running
# -------------------------
- name: Wait for pods to be Running
  command: >
    oc get pods -n {{ namespace }} -l {{ component.selector }} -o json
  register: pod_status_running
  retries: "{{ retry_count }}"
  delay: "{{ retry_delay }}"
  until: >
    (
      (pod_status_running.stdout | from_json).get('items', [])
      | selectattr('status.phase', 'equalto', 'Running')
      | list | length
    )
    ==
    (
      (pod_status_running.stdout | from_json).get('items', [])
      | length
    )
  failed_when: false

# -------------------------
# WAIT PHASE 3: Ready
# -------------------------
- name: Wait for containers to be ready
  command: >
    oc get pods -n {{ namespace }} -l {{ component.selector }} -o json
  register: pod_status_ready
  retries: "{{ retry_count }}"
  delay: "{{ retry_delay }}"
  until: >
    (
      (
        (pod_status_ready.stdout | from_json).get('items', [])
        | map(attribute='status.containerStatuses')
        | select('defined')
        | flatten
        | selectattr('ready', 'equalto', true)
        | list | length
      )
      >=
      (
        (pod_status_ready.stdout | from_json).get('items', [])
        | map(attribute='status.containerStatuses')
        | select('defined')
        | flatten
        | list | length
      )
    )
  failed_when: false

# -------------------------
# FINAL POD LIST
# -------------------------
- name: Parse final pod list
  set_fact:
    pod_list: "{{ pod_status_ready.stdout | from_json }}"

- name: DEBUG pod list
  debug:
    var: pod_list.get('items', [])

