# 📄 tasks/process_component.yml (🔥 FINAL FIXED)

```yaml
---
- name: Get workloads for component {{ component.name }}
  command: >
    oc get deployment,statefulset -n {{ namespace }}
    -l {{ component.selector }} -o json
  register: workload_json
  failed_when: false

- name: Parse workloads
  set_fact:
    workloads: "{{ workload_json.stdout | from_json }}"

- name: Restart workloads
  command: >
    oc rollout restart {{ item.kind | lower }}/{{ item.metadata.name }} -n {{ namespace }}
  loop: "{{ workloads.get('items', []) }}"
  when: workloads.get('items', []) | length > 0
  failed_when: false

# -----------------------------
# WAIT FOR REAL READINESS
# -----------------------------
- name: Wait for pods to be fully ready
  command: >
    oc get pods -n {{ namespace }} -l {{ component.selector }} -o json
  register: pod_status
  retries: "{{ retry_count }}"
  delay: "{{ retry_delay }}"
  until: >
    (
      (
        (pod_status.stdout | from_json).get('items', [])
        | selectattr('status.phase', 'equalto', 'Running')
        | list | length
      )
      ==
      (
        (pod_status.stdout | from_json).get('items', [])
        | list | length
      )
    )
    and
    (
      (
        (pod_status.stdout | from_json).get('items', [])
        | map(attribute='status.containerStatuses')
        | flatten
        | selectattr('ready', 'equalto', true)
        | list | length
      )
      ==
      (
        (pod_status.stdout | from_json).get('items', [])
        | map(attribute='status.containerStatuses')
        | flatten
        | list | length
      )
    )
  failed_when: false

- name: Parse pod list
  set_fact:
    pod_list: "{{ pod_status.stdout | from_json }}"

# -----------------------------
# BUILD AUDIT
# -----------------------------
- name: Build component audit result
  set_fact:
    component_result:
      component: "{{ component.name }}"
      pods: "{{ pod_list.get('items', []) | map(attribute='metadata.name') | list }}"
      pod_details: "{{ pod_list.get('items', []) }}"

# -----------------------------
# FAILURE DETECTION
# -----------------------------
- name: Detect failures
  set_fact:
    component_result: "{{ component_result | combine({'status': comp_status}) }}"
  vars:
    comp_status: >-
      {{
        'FAILED' if (
          (
            pod_list.get('items', [])
            | selectattr('status.phase', 'ne', 'Running')
            | list | length
          ) > 0
          or
          (
            pod_list.get('items', [])
            | selectattr('status.containerStatuses', 'defined')
            | map(attribute='status.containerStatuses')
            | flatten
            | selectattr('ready', 'equalto', false)
            | list | length
          ) > 0
        )
        else 'SUCCESS'
      }}

# -----------------------------
# APPEND RESULT
# -----------------------------
- name: Append to audit results
  set_fact:
    audit_results: "{{ audit_results + [component_result] }}"
```

