  set_fact:
    component_result:
      component: "{{ component.name }}"
      pods: "{{ pod_list.get('items', []) | map(attribute='metadata.name') | list }}"
      pod_details: "{{ pod_list.get('items', []) }}"
      status: "{{ 'FAILED' if (pod_list.get('items', []) | length == 0) else 'SUCCESS' }}"

- name: Append result
  set_fact:
    audit_results: "{{ audit_results + [component_result] }}"
